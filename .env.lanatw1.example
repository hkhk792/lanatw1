# -----------------------------------------------------------------------------
# lanatw1.com — 方案 B（独立品牌/SEO，共用 Supabase 订单后台）
# 复制到 Vercel 项目 Environment Variables（Production + Preview）
# 与 sp2spods.com 项目使用同一套 SUPABASE_*、ADMIN_SECRET
# -----------------------------------------------------------------------------

# 订单写入 orders.site_code，后台 /admin2589 可按站点筛选
SITE_CODE=lanatw1

# 主域与 SEO（build 时写入 canonical、sitemap、index.html）
VITE_SHOP_SITE_URL=https://lanatw1.com
VITE_SHOP_HOME_TITLE=LANA 小蠻腰煙彈官方商城｜LANA Pod Taiwan 現貨配送
VITE_SHOP_HOME_DESCRIPTION=LANA 小蠻腰煙彈官方商城，提供 LANA 皮革主機、煙彈 3 顆裝與一代通配系列，台灣現貨快速出貨、超商取貨付款，滿額免運。僅限 18 歲以上選購，支援 LINE 客服確認口味與庫存。
VITE_SHOP_ORG_NAME=LANA 官方
VITE_SHOP_WEBSITE_NAME=LANA 電子煙官方商城
VITE_SHOP_JSON_LD_BRAND=LANA

# 与主站相同（从 sp2spods Vercel 项目复制）
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ADMIN_SECRET=
# EDGE_ACCESS_SECRET=
