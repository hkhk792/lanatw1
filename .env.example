# -----------------------------------------------------------------------------
# Orders API (api/orders.js) only runs when:
#   - Deployed on Vercel, OR
#   - Locally: `npm run dev:vercel` (needs Vercel CLI + env copied into .env.local)
# Plain `npm run dev` (Vite only) does NOT serve /api/orders — checkout cannot write DB.
# -----------------------------------------------------------------------------
# Order API: choose Supabase (transactional stock) or Airtable (legacy)
# - If ORDER_BACKEND is empty, Supabase wins when SUPABASE_URL + key are set;
#   otherwise Airtable when configured.
# ORDER_BACKEND=supabase
# ORDER_BACKEND=airtable

# Supabase (PostgreSQL) — apply sql from supabase/migrations/*.sql in Dashboard SQL editor
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# /admin 後台：請填強隨機字串；前端輸入同一密鑰呼叫 /api/admin/orders
ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Airtable (optional fallback)
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_ORDERS_TABLE=訂單
AIRTABLE_ITEMS_TABLE=訂單明細

# Optional: map Airtable field names (change only if your column names differ)
# 與 Supabase 一致：待确认 | 已发出 | 已取消 | 异常
AIRTABLE_ORDER_DEFAULT_STATUS=待确认
# 若 Airtable 訂單表有「截單日期」欄位（Date），填寫欄位名以寫入 batch_date
# AIRTABLE_BATCH_DATE_FIELD=截單日期
AIRTABLE_ORDER_STATUS_FIELD=訂單狀態
AIRTABLE_ORDER_NUMBER_FIELD=訂單編號
AIRTABLE_CUSTOMER_NAME_FIELD=姓名
AIRTABLE_PHONE_FIELD=手機號碼
AIRTABLE_SHIPPING_ADDRESS_FIELD=收貨地址
AIRTABLE_PICKUP_STORE_CODE_FIELD=收貨門市號
AIRTABLE_LINE_ID_FIELD=LINE ID
AIRTABLE_ORDER_NOTES_FIELD=訂單備註
AIRTABLE_SUBTOTAL_FIELD=商品小計 TWD
AIRTABLE_SHIPPING_FIELD=運費 TWD
AIRTABLE_TOTAL_FIELD=訂單合計 TWD

AIRTABLE_ITEM_ORDER_LINK_FIELD=所屬訂單
AIRTABLE_ITEM_PRODUCT_MODEL_FIELD=商品型號
AIRTABLE_ITEM_QUANTITY_FIELD=數量
AIRTABLE_ITEM_VARIANT_FIELD=規格/口味
AIRTABLE_ITEM_UNIT_PRICE_FIELD=單價 TWD
AIRTABLE_ITEM_LINE_TOTAL_FIELD=行小計 TWD
AIRTABLE_ITEM_PRODUCT_ID_FIELD=productId
AIRTABLE_ITEM_IMAGE_URL_FIELD=圖片 URL
